# Application
SERVICE_NAME=optimizer
PORT=50052
HEALTH_PORT=8081
APP_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
TOPIC=vehicle.telemetry
GROUP_ID=optimizer-group

# Redis
REDIS_ADDR=localhost:6379

# PostgreSQL
POSTGRES_DSN=postgres://postgres:password@localhost:5432/gridflow?sslmode=disable

# Etcd
ETCD_ENDPOINTS=localhost:2379

# Jaeger
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# AI
AI_ENDPOINT=http://localhost:8000/predict